{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Run BuildFlow Extension",
			"type": "extensionHost",
			"request": "launch",
			"args": [
				"--extensionDevelopmentPath=${workspaceFolder}/buildflow"
			],
			"outFiles": [
				"${workspaceFolder}/buildflow/dist/**/*.js"
			],
			"preLaunchTask": "buildflow: npm watch"
		}
	]
}
