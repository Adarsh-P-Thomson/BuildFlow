{
  "name": "buildflow",
  "displayName": "BuildFlow",
  "description": "Lightweight project planning and task management tool",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:buildflow.sidebar",
    "onCommand:buildflow.createProject",
    "onCommand:buildflow.renameProject",
    "onCommand:buildflow.deleteProject",
    "onCommand:buildflow.addCategory",
    "onCommand:buildflow.renameCategory",
    "onCommand:buildflow.removeCategory",
    "onCommand:buildflow.addTask",
    "onCommand:buildflow.editTask",
    "onCommand:buildflow.deleteTask",
    "onCommand:buildflow.addGameplanStep",
    "onCommand:buildflow.removeGameplanStep",
    "onCommand:buildflow.toggleGameplanStepComplete",
    "onCommand:buildflow.toggleTaskStatus",
    "onCommand:buildflow.refresh"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "id": "buildflow.sidebar",
          "name": "BuildFlow"
        }
      ]
    },
    "commands": [
      {
        "command": "buildflow.createProject",
        "title": "Add",
        "icon": "$(add)"
      },
      {
        "command": "buildflow.renameProject",
        "title": "BuildFlow: Rename Project",
        "icon": "$(edit)"
      },
      {
        "command": "buildflow.deleteProject",
        "title": "BuildFlow: Delete Project",
        "icon": "$(trash)"
      },
      {
        "command": "buildflow.addCategory",
        "title": "BuildFlow: Add Category",
        "icon": "$(add)"
      },
      {
        "command": "buildflow.renameCategory",
        "title": "BuildFlow: Rename Category",
        "icon": "$(edit)"
      },
      {
        "command": "buildflow.removeCategory",
        "title": "BuildFlow: Remove Category",
        "icon": "$(trash)"
      },
      {
        "command": "buildflow.addTask",
        "title": "BuildFlow: Add Task",
        "icon": "$(add)"
      },
      {
        "command": "buildflow.editTask",
        "title": "BuildFlow: Edit Task",
        "icon": "$(edit)"
      },
      {
        "command": "buildflow.deleteTask",
        "title": "BuildFlow: Delete Task",
        "icon": "$(trash)"
      },
      {
        "command": "buildflow.addGameplanStep",
        "title": "BuildFlow: Add Gameplan Step",
        "icon": "$(add)"
      },
      {
        "command": "buildflow.removeGameplanStep",
        "title": "BuildFlow: Remove Gameplan Step"
      },
      {
        "command": "buildflow.toggleGameplanStepComplete",
        "title": "BuildFlow: Toggle Step Complete"
      },
      {
        "command": "buildflow.toggleTaskStatus",
        "title": "BuildFlow: Toggle Task Status"
      },
      {
        "command": "buildflow.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "buildflow.createProject",
          "when": "view == buildflow.sidebar",
          "group": "navigation@1"
        },
        {
          "command": "buildflow.refresh",
          "when": "view == buildflow.sidebar",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "buildflow.addCategory",
          "when": "view == buildflow.sidebar && viewItem == project",
          "group": "inline@1"
        },
        {
          "command": "buildflow.renameProject",
          "when": "view == buildflow.sidebar && viewItem == project",
          "group": "inline@2"
        },
        {
          "command": "buildflow.deleteProject",
          "when": "view == buildflow.sidebar && viewItem == project",
          "group": "inline@3"
        },
        {
          "command": "buildflow.addTask",
          "when": "view == buildflow.sidebar && viewItem == category",
          "group": "inline@1"
        },
        {
          "command": "buildflow.renameCategory",
          "when": "view == buildflow.sidebar && viewItem == category",
          "group": "inline@2"
        },
        {
          "command": "buildflow.removeCategory",
          "when": "view == buildflow.sidebar && viewItem == category",
          "group": "inline@3"
        },
        {
          "command": "buildflow.addGameplanStep",
          "when": "view == buildflow.sidebar && viewItem == task",
          "group": "inline@1"
        },
        {
          "command": "buildflow.editTask",
          "when": "view == buildflow.sidebar && viewItem == task",
          "group": "inline@2"
        },
        {
          "command": "buildflow.deleteTask",
          "when": "view == buildflow.sidebar && viewItem == task",
          "group": "inline@3"
        },
        {
          "command": "buildflow.removeGameplanStep",
          "when": "view == buildflow.sidebar && viewItem == step",
          "group": "buildflow@1"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "ts-loader": "^9.5.4",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
